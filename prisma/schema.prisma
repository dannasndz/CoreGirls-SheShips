generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  posts            Post[]
  likes            Like[]
  comments         Comment[]
  quizResult       QuizResult?
  groupMemberships GroupMember[]
  groupPosts       GroupPost[]
  groupPostLikes   GroupPostLike[]
  groupPostComments GroupPostComment[]
  events            Event[]
  eventAttendances  EventAttendee[]
}

model Post {
  id         String   @id @default(cuid())
  title      String
  content    String
  categories Json     @default("[]")
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  likes    Like[]
  comments Comment[]
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  authorId String
  author   User @relation(fields: [authorId], references: [id])
  postId   String
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())

  members GroupMember[]
  posts   GroupPost[]
}

model GroupMember {
  id       String @id @default(cuid())
  role     String @default("member")
  joinedAt DateTime @default(now())

  userId  String
  user    User  @relation(fields: [userId], references: [id])
  groupId String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model GroupPost {
  id         String   @id @default(cuid())
  title      String
  content    String
  categories Json     @default("[]")
  tags       Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  authorId String
  author   User            @relation(fields: [authorId], references: [id])
  groupId  String
  group    Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes    GroupPostLike[]
  comments GroupPostComment[]
}

model GroupPostLike {
  id     String @id @default(cuid())
  userId String
  postId String

  user User      @relation(fields: [userId], references: [id])
  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model GroupPostComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  postId   String
  post     GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Event {
  id               String   @id @default(cuid())
  title            String
  description      String
  modality         String   // "in-person", "remote", "hybrid"
  location         String?  // required if in-person or hybrid
  meetingLink      String?  // required if remote or hybrid
  externalLink     String?  // optional link to external info page
  date             DateTime
  hour             String   // e.g. "14:00"
  participantsLimit Int?
  organizerName    String
  cancelled        Boolean  @default(false)
  createdAt        DateTime @default(now())

  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  attendees   EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User  @relation(fields: [userId], references: [id])
  eventId String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String   @unique
  answers   Json
  career    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
